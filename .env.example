# WakeAgain production / local env template
# Copy to .env and fill. Never commit real secrets.

# Required before public deploy
APP_SECRET=change-me-long-random
JWT_SECRET=
ADMIN_SECRET=change-me-admin-secret

# Email codes — production: EMAIL_DEV_MODE=0 and EMAIL_CODE_FALLBACK=0
EMAIL_DEV_MODE=1
# SMTP failure must NOT return codes in API on public deploy
EMAIL_CODE_FALLBACK=0
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Public URL (OAuth redirect base after domain)
OAUTH_PUBLIC_BASE=http://127.0.0.1:8080
# PUBLIC_BASE_URL=https://wakeagain.com

# SNS (optional — enable when keys issued)
# KAKAO_CLIENT_ID=
# KAKAO_CLIENT_SECRET=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# CORS: leave unset for secure defaults, or comma list.
# Explicit * only for local debug (not production).
# ALLOWED_ORIGINS=https://wakeagain.com,https://www.wakeagain.com,capacitor://localhost

# Auction background closer (default on)
AUCTION_SCHEDULER=1
AUCTION_SCHEDULER_SEC=60

# Data directory (production Railway volume: /data)
# DATA_DIR=./data

# SQLite member-data protection (default ON)
# DB_BACKUP_ENABLED=1
# DB_BACKUP_INTERVAL_SEC=3600
# DB_BACKUP_KEEP_HOURLY=48
# DB_BACKUP_KEEP_DAILY=14
# Member wipe / DB restore — leave OFF in production unless you are actively recovering
# ALLOW_DESTRUCTIVE_ADMIN=0

# Off-site backup (S3-compatible: Cloudflare R2 recommended)
# See docs/OFFSITE_BACKUP_SETUP.md
# OFFSITE_BACKUP_ENABLED=1
# OFFSITE_S3_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# OFFSITE_S3_BUCKET=wakeagain-backups
# OFFSITE_S3_ACCESS_KEY=
# OFFSITE_S3_SECRET_KEY=
# OFFSITE_S3_REGION=auto
# OFFSITE_S3_PREFIX=wakeagain/
# OFFSITE_S3_FORCE_PATH_STYLE=1
# OFFSITE_KEEP_REMOTE=60
